# ── Python cache ──────────────────────────────────────────
__pycache__/

# ── Crawl progress (local state) ──────────────────────────
progress.json
soul_progress.json
# 历史上爬虫会同时输出 *.js 副本（var XXX_DATA = ...）。前端不再依赖，
# 爬虫已不生成；此规则作为保险，防止误生成文件被入库。
data/*.js

# ── Lookup / intermediate files (large altema scrapes + lookup tables) ──
_lookup/

# ── Local revise overrides (applied locally, not for Pages) ──
*_revise.json
data/omoide_templates.json

# ── Local-only progress markers (per-item check state, never published) ──
data/soul_check.json
data/characters_check.json
data/crystals_check.json
data/bladegraph_check.json

# ── Docs not for Pages: 只 commit chara_training / structure / senzai_icon_table ──
docs/checklist.md
docs/frontend_ui.md
docs/hensei.md
docs/motion_table.md
docs/skills_schema.md
docs/*_doc_cn.md
docs/draft_doc_cn.md

# ── Audit one-time analysis (gitignored, local only) ──────
audit/

